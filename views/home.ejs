<div class="container-fluid pt-4">

    <!-- Cabeçalho da Página -->
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800 font-weight-bold">Painel de Controle</h1>
        <!-- Se precisar do botão de relatório no futuro, implemente de verdade. Não deixe código morto na view. -->
    </div>

    <!-- Linha dos Cards de Resumo de Animais e Adoções -->
    <div class="row">

        <!-- Card: Animais Disponíveis -->
        <div class="col-xl-4 col-md-6 mb-4">
            <div class="card border-left-warning shadow-sm h-100 py-2 border-0" style="border-radius: 1rem; border-left: 5px solid #f6c23e !important;">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-warning text-uppercase mb-1" style="color: #f6c23e !important;">
                                Animais Disponíveis
                            </div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">
                                <%= locals.totalDisponiveis || 0 %>
                            </div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-paw fa-2x text-warning opacity-50"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Card: Total Adotados -->
        <div class="col-xl-4 col-md-6 mb-4">
            <div class="card border-left-success shadow-sm h-100 py-2 border-0" style="border-radius: 1rem; border-left: 5px solid #1cc88a !important;">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-success text-uppercase mb-1">
                                Total de Adotados
                            </div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">
                                <%= locals.totalAdotados || 0 %>
                            </div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-heart fa-2x text-success opacity-50"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Card: Adoções Pendentes -->
        <div class="col-xl-4 col-md-6 mb-4">
            <div class="card border-left-danger shadow-sm h-100 py-2 border-0" style="border-radius: 1rem; border-left: 5px solid #e74a3b !important;">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-danger text-uppercase mb-1">
                                Adoções Pendentes
                            </div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">
                                <%= locals.totalPendentes || 0 %>
                            </div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-clock fa-2x text-danger opacity-50"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Linha dos Cards de Resumo Financeiro -->
    <div class="row">

        <!-- Card: Doação (Mês atual) -->
        <div class="col-xl-4 col-md-6 mb-4">
            <div class="card border-left-primary shadow-sm h-100 py-2 border-0" style="border-radius: 1rem; border-left: 5px solid #4e73df !important;">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">
                                Doação em dinheiro (Mês atual)
                            </div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">
                                R$<%= (saldoMesAtual || 0).toLocaleString('pt-BR', { minimumFractionDigits: 2 }) %>
                            </div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-calendar-alt fa-2x text-primary opacity-50"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Card: Doação (Anual) -->
        <div class="col-xl-4 col-md-6 mb-4">
            <div class="card border-left-primary shadow-sm h-100 py-2 border-0" style="border-radius: 1rem; border-left: 5px solid #36b9cc !important;">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-info text-uppercase mb-1" style="color: #36b9cc !important;">
                                Doação em dinheiro (Anual)
                            </div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">
                                R$<%= (saldoAnoAtual || 0).toLocaleString('pt-BR', { minimumFractionDigits: 2 }) %>
                            </div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-dollar-sign fa-2x text-info opacity-50"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Card: Controle de Eventos -->
        <div class="col-xl-4 col-md-6 mb-4">
            <div class="card border-left-info shadow-sm h-100 py-2 border-0" style="border-radius: 1rem; border-left: 5px solid #858796 !important;">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-secondary text-uppercase mb-1">
                                Inventário/Eventos em aberto
                            </div>
                            <div class="row no-gutters align-items-center mt-2">
                                <div class="col-auto">
                                    <div class="h5 mb-0 mr-3 font-weight-bold text-gray-800"><%= qntEmAberto || 0 %></div>
                                </div>
                                <div class="col">
                                    <div class="progress progress-sm mr-2" style="height: 8px; border-radius: 4px;">
                                        <div class="progress-bar bg-info" role="progressbar"
                                            style="width: <%= qntEmAbertoPorcen || 0 %>%" 
                                            aria-valuenow="<%= qntEmAbertoPorcen || 0 %>" 
                                            aria-valuemin="0"
                                            aria-valuemax="100">
                                        </div>
                                    </div>
                                </div>
                                <div class="col-auto">
                                    <small class="text-muted"><%= qntEmAbertoPorcen || 0 %>%</small>
                                </div>
                            </div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-tasks fa-2x text-gray-400 opacity-50"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

    </div>

</div>