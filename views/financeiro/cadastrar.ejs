<div class="container-fluid">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <h1 class="h3 mb-4 text-gray-800 fw-bold">Registrar Entrada Manual</h1>

            <div class="card shadow-sm border-0" style="border-radius: 1rem;">
                <div class="card-body p-4 p-md-5">
                    <form action="/financeiro/cadastrar" method="POST">
                        <!-- Dados da Doação -->
                        <div class="row g-3 mb-4">
                            <h5 class="fw-bold mb-0">Informações da Transação</h5>
                            <div class="col-md-6">
                                <label class="form-label">Valor (R$)<span class="text-danger">*</span></label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0">R$</span>
                                    <input name="valor" class="form-control form-control-lg fw-bold text-success border-start-0" type="number" step="0.01" value="0.00" required>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Método<span class="text-danger">*</span></label>
                                <select name="metodo" class="form-select" required>
                                    <option value="pix">PIX</option>
                                    <option value="cartao">Cartão de Crédito</option>
                                    <option value="boleto">Boleto</option>
                                    <option value="dinheiro">Dinheiro</option>
                                </select>
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Frequência<span class="text-danger">*</span></label>
                                <select name="recorrencia" class="form-select" required>
                                    <option value="unica">Única</option>
                                    <option value="mensal">Mensal / Recorrente</option>
                                </select>
                            </div>
                        </div>

                        <hr class="my-4 opacity-10">

                        <!-- Dados do Doador -->
                        <div class="row g-3 mb-4">
                            <h5 class="fw-bold mb-0">Identificação do Doador</h5>
                            <div class="col-md-8">
                                <label class="form-label">Nome Completo</label>
                                <input name="nome" class="form-control" type="text" placeholder="Nome ou Razão Social">
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">CPF/CNPJ</label>
                                <input name="cpf" class="form-control" type="text" placeholder="000.000.000-00">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">E-mail</label>
                                <input name="email" class="form-control" type="email" placeholder="exemplo@email.com">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Telefone</label>
                                <input name="tel" class="form-control" type="tel" placeholder="(00) 00000-0000">
                            </div>
                        </div>

                        <div class="mt-5 d-flex gap-2">
                            <button type="submit" class="btn btn-success px-5 py-2 fw-bold">Salvar Doação</button>
                            <a href="/financeiro/listar" class="btn btn-outline-secondary px-5 py-2">Cancelar</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
