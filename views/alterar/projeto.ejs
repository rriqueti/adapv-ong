<script src="/js/alterar/projeto.js"></script>
<link rel="stylesheet" href="/css/Multiselect.css">

<div class="container py-4">
    <div class="card shadow-sm border-0" style="border-radius: 1rem;">
        <div class="card-body p-4">
            <h1 class="h3 mb-4 fw-bold text-gray-800">
                <i class="fas fa-edit me-2" style="color:var(--btn-primary-bg);"></i>
                Alterar Projeto / Evento
            </h1>

            <input id="id" hidden value="<%= projeto.pro_id %>">
            <input id="createdAt" hidden value="<%= projeto.createdAt %>">

            <form id="formProjeto" enctype="multipart/form-data">
                <div class="row g-3">
                    <div class="col-md-8">
                        <label for="nomePro" class="form-label fw-semibold">Nome do Projeto <span class="text-danger">*</span></label>
                        <input type="text" value="<%= projeto.pro_nome %>" name="nome" class="form-control" id="nomePro">
                    </div>

                    <div class="col-md-4">
                        <label for="dataPro" class="form-label fw-semibold">Data do Projeto <span class="text-danger">*</span></label>
                        <input type="date" value="<%= projeto.pro_data %>" name="data" class="form-control" id="dataPro">
                    </div>

                    <div class="col-12">
                        <label for="descPro" class="form-label fw-semibold">Descrição do Projeto <span class="text-danger">*</span></label>
                        <input type="text" value="<%= projeto.pro_desc %>" name="desc" class="form-control" id="descPro">
                    </div>

                    <div class="col-12">
                        <label for="objetivoPro" class="form-label fw-semibold">Objetivo do Projeto</label>
                        <textarea name="objetivo" class="form-control" id="objetivoPro" rows="3"><%= projeto.pro_objetivo %></textarea>
                    </div>

                    <div class="col-md-6">
                        <label for="voluntariosPro" class="form-label fw-semibold">Vincular Voluntários</label>
                        <select name="voluntarios" id="voluntariosPro" class="form-select" multiple>
                            <% if (locals.listaVol && listaVol.length > 0) { %>
                                <% listaVol.forEach(v => { %>
                                    <option value="<%= v.vol_id %>" <%= idsVinculados.includes(v.vol_id) ? 'selected' : '' %> >
                                        <%= v.pess_nome %>
                                    </option>
                                <% }) %>
                            <% } %>
                        </select>
                        <small class="text-muted">Pressione Ctrl (ou Cmd) para selecionar múltiplos voluntários.</small>
                    </div>

                    <div class="col-md-6">
                        <label for="bannerPro" class="form-label fw-semibold">Alterar Banner / Imagem</label>
                        <input type="file" name="banner" class="form-control" id="bannerPro" accept="image/*">
                        
                        <div id="previewContainer" class="mt-2 <%= projeto.pro_banner ? '' : 'd-none' %>">
                            <label class="d-block text-muted mb-1" style="font-size: 0.8rem;">Banner Atual / Novo:</label>
                            <img id="bannerPreview" src="<%= projeto.pro_banner ? '/uploads/projetos/' + projeto.pro_banner : '#' %>" 
                                 alt="Preview" class="img-fluid rounded" style="max-height: 150px;">
                        </div>
                    </div>
                </div>

                <div class="mt-5 d-flex gap-2">
                    <button type="button" class="btn btn-success px-4 py-2 fw-bold" id="btnAlterar">
                        <i class="fas fa-save me-2"></i>Salvar Alterações
                    </button>
                    <button type="button" class="btn btn-light px-4 py-2 fw-bold" id="cancelar">
                        Cancelar
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    // Preview da imagem
    document.getElementById('bannerPro').onchange = evt => {
        const [file] = document.getElementById('bannerPro').files;
        if (file) {
            document.getElementById('bannerPreview').src = URL.createObjectURL(file);
            document.getElementById('previewContainer').classList.remove('d-none');
        }
    }
</script>
