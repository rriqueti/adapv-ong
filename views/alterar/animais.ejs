<div class="container-fluid">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <h1 class="h3 mb-4 text-gray-800 fw-bold">Alterar Animal</h1>

            <div class="card shadow-sm border-0" style="border-radius: 1rem;">
                <div class="card-body p-4 p-md-5">
                    <form id="formAnimal">
                        <input type="hidden" id="id" value="<%= animais.ani_id %>">
                        <input type="hidden" id="createdAt" value="<%= animais.createdAt %>">

                        <!-- Informações Básicas -->
                        <div class="row g-3 mb-4">
                            <h5 class="fw-bold mb-0">Informações Básicas</h5>
                            <div class="col-md-8">
                                <label for="nome" class="form-label">Nome do Animal<span class="text-danger">*</span></label>
                                <input type="text" id="nome" class="form-control" value="<%= animais.ani_nome %>" required>
                            </div>
                            <div class="col-md-4">
                                <label for="sexo" class="form-label">Sexo<span class="text-danger">*</span></label>
                                <select id="sexo" class="form-select" required>
                                    <option value="Macho" <%= animais.ani_sexo === 'Macho' ? 'selected' : '' %>>Macho</option>
                                    <option value="Femea" <%= animais.ani_sexo === 'Femea' ? 'selected' : '' %>>Fêmea</option>
                                    <option value="Indefinido" <%= animais.ani_sexo === 'Indefinido' ? 'selected' : '' %>>Indefinido</option>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label for="especie" class="form-label">Espécie<span class="text-danger">*</span></label>
                                <select id="especie" class="form-select" required>
                                    <% listaEspecies.forEach(function(esp) { %>
                                        <option value="<%= esp.esp_id %>" <%= String(animais.ani_especie) === String(esp.esp_id) ? 'selected' : '' %>><%= esp.esp_nome %></option>
                                    <% }); %>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label for="raca" class="form-label">Raça</label>
                                <input type="text" id="raca" class="form-control" value="<%= animais.ani_raca %>">
                            </div>
                        </div>

                        <hr class="my-4 opacity-10">

                        <!-- Saúde e Estado -->
                        <div class="row g-3 mb-4">
                            <h5 class="fw-bold mb-0">Estado e Localização</h5>
                            <div class="col-md-6">
                                <label for="campoData" class="form-label">Data de Nascimento</label>
                                <input type="date" id="campoData" class="form-control" value="<%= animais.ani_nascimento %>" <%= !animais.ani_nascimento ? 'disabled' : '' %>>
                                <div class="form-check mt-2">
                                    <input class="form-check-input" type="checkbox" id="dataDesconhecida" name="dataDesconhecida" <%= !animais.ani_nascimento ? 'checked' : '' %>>
                                    <label class="form-check-label" for="dataDesconhecida">
                                        Data de nascimento desconhecida
                                    </label>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <label for="localidade" class="form-label">Localização Atual<span class="text-danger">*</span></label>
                                <select id="localidade" class="form-select" required>
                                    <option value="ONG" <%= animais.ani_localidade === 'ONG' ? 'selected' : '' %>>Habitando na ONG</option>
                                    <option value="Lar provisório" <%= animais.ani_localidade === 'Lar provisório' ? 'selected' : '' %>>Lar provisório</option>
                                    <option value="Abandonado" <%= animais.ani_localidade === 'Abandonado' ? 'selected' : '' %>>Abandonado</option>
                                </select>
                            </div>
                            
                            <div class="col-md-4">
                                <label for="disp" class="form-label">Disponível para Adoção?<span class="text-danger">*</span></label>
                                <select id="disp" class="form-select" required>
                                    <option value="Sim" <%= animais.ani_disponivel === 'Sim' ? 'selected' : '' %>>Sim</option>
                                    <option value="Nao" <%= animais.ani_disponivel === 'Nao' ? 'selected' : '' %>>Não</option>
                                </select>
                            </div>

                            <div class="col-md-4">
                                <label for="ester" class="form-label">Esterilização</label>
                                <select id="ester" class="form-select">
                                    <option value="Indefinido" <%= animais.ani_ester === 'Indefinido' ? 'selected' : '' %>>Não informado</option>
                                    <option value="Fertil" <%= animais.ani_ester === 'Fertil' ? 'selected' : '' %>>Fértil</option>
                                    <option value="Castrado" <%= animais.ani_ester === 'Castrado' ? 'selected' : '' %>>Castrado</option>
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label for="pelagem" class="form-label">Pelagem</label>
                                <input type="text" id="pelagem" class="form-control" value="<%= animais.ani_pelagem %>">
                            </div>
                        </div>

                        <hr class="my-4 opacity-10">

                        <!-- Descrição -->
                        <div class="row g-3 mb-4">
                            <h5 class="fw-bold mb-0">Detalhes Adicionais</h5>
                            <div class="col-12">
                                <label for="desc" class="form-label">Descrição / Observações</label>
                                <textarea id="desc" class="form-control" rows="4"><%= animais.ani_descricao %></textarea>
                            </div>
                        </div>

                        <div class="mt-5 d-flex gap-2">
                            <button type="submit" class="btn btn-success px-5 py-2 fw-bold" id="btnSalvar">Salvar Alterações</button>
                            <a href="/animais/listar" class="btn btn-outline-secondary px-5 py-2">Cancelar</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="/js/alterar/animais.js" defer></script>