<div class="container-fluid">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <h1 class="h3 mb-4 text-gray-800 fw-bold">Alterar Dados do Usuário</h1>

            <div class="card shadow-sm border-0" style="border-radius: 1rem;">
                <div class="card-body p-4 p-md-5">
                    <form id="formUsuario">
                        <input type="hidden" id="usu_id" value="<%= usuario.id %>">

                        <div class="row g-3 mb-4">
                            <h5 class="fw-bold mb-0">Informações Pessoais</h5>
                            <div class="col-md-12">
                                <label for="nome" class="form-label">Nome Completo</label>
                                <input type="text" id="nome" class="form-control bg-light" value="<%= usuario.nome %>" disabled>
                                <div class="form-text mt-2 text-muted">Para alterar o nome, acesse a gestão de Pessoas.</div>
                            </div>
                        </div>

                        <hr class="my-4 opacity-10">

                        <div class="row g-3 mb-4">
                            <h5 class="fw-bold mb-0">Credenciais e Permissões</h5>
                            <div class="col-md-6">
                                <label for="email" class="form-label">E-mail (Login)<span class="text-danger">*</span></label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0"><i class="fas fa-envelope text-muted"></i></span>
                                    <input type="email" id="email" class="form-control border-start-0" value="<%= usuario.email %>" required>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <label for="perfil_id" class="form-label">Perfil de Acesso<span class="text-danger">*</span></label>
                                <select id="perfil_id" class="form-select" required>
                                    <% for (let i = 0; i < perfis.length; i++) { %>
                                        <option value="<%= perfis[i].perf_id %>" <%= usuario.perfil_id == perfis[i].perf_id ? 'selected' : '' %>>
                                            <%= perfis[i].perf_nome %>
                                        </option>
                                    <% } %>
                                </select>
                            </div>
                            <div class="col-md-12 mt-4">
                                <div class="p-3 bg-light rounded" style="border-left: 4px solid var(--primary-purple);">
                                    <label for="senha" class="form-label fw-bold">Redefinir Senha (Opcional)</label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-white border-end-0"><i class="fas fa-key text-muted"></i></span>
                                        <input type="password" id="senha" class="form-control border-start-0 bg-white" placeholder="Deixe em branco para manter a senha atual">
                                    </div>
                                    <div class="form-text mt-1 text-muted small">Só preencha este campo se desejar alterar a senha do usuário.</div>
                                </div>
                            </div>
                        </div>

                        <div class="mt-5 d-flex gap-2">
                            <button type="submit" class="btn btn-primary px-5 py-2 fw-bold" id="btnSalvar">Salvar Alterações</button>
                            <a href="/usuarios/listar" class="btn btn-outline-secondary px-5 py-2">Cancelar</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    document.getElementById('formUsuario').addEventListener('submit', function(e) {
        e.preventDefault();

        const data = {
            id: document.getElementById('usu_id').value,
            email: document.getElementById('email').value,
            perfil_id: document.getElementById('perfil_id').value,
            senha: document.getElementById('senha').value
        };

        if (!data.email || !data.perfil_id) {
            return Swal.fire('Erro!', 'Preencha o email e o perfil de acesso.', 'error');
        }

        Swal.fire({
            title: 'Salvar Alterações?',
            text: "Os novos dados de acesso serão aplicados imediatamente.",
            icon: 'question',
            showCancelButton: true,
            confirmButtonColor: '#7c3aed',
            confirmButtonText: 'Sim, atualizar',
            cancelButtonText: 'Revisar'
        }).then((result) => {
            if (result.isConfirmed) {
                fetch('/usuarios/alterar', {
                    method: 'POST',
                    body: JSON.stringify(data),
                    headers: { 'Content-Type': 'application/json' }
                })
                .then(res => res.json())
                .then(res => {
                    if (res.ok) {
                        Swal.fire({
                            icon: 'success',
                            title: 'Atualizado!',
                            text: res.msg,
                            timer: 2000,
                            showConfirmButton: false
                        }).then(() => {
                            window.location.href = '/usuarios/listar';
                        });
                    } else {
                        Swal.fire('Erro!', res.msg, 'error');
                    }
                })
                .catch(err => {
                    console.error(err);
                    Swal.fire('Erro!', 'Falha de comunicação com o servidor.', 'error');
                });
            }
        });
    });
});
</script>
