<link rel="stylesheet" type="text/css" media="print" href="/css/print.css">
<script src="https://cdn.sheetjs.com/xlsx-0.20.2/package/dist/xlsx.full.min.js"></script>
<script src="/js/listar/atividades.js"></script>

<div class="container-fluid py-4">
    <div class="d-flex align-items-center justify-content-between mb-4">
        <div>
            <h1 class="h3 mb-0 fw-bold text-gray-800">Gestão de Atividades</h1>
            <p class="text-muted small mb-0">Planejamento e vinculação de voluntários para atividades da ONG.</p>
        </div>
        <div class="d-flex gap-2">
            <a href="/atividades/cadastrar" class="btn btn-purple shadow-sm fw-bold">
                <i class="fas fa-plus me-2"></i>Nova Atividade
            </a>
            <div class="dropdown">
                <button class="btn btn-outline-secondary dropdown-toggle fw-bold" type="button" data-bs-toggle="dropdown">
                    <i class="fas fa-download me-2"></i>Exportar
                </button>
                <ul class="dropdown-menu shadow border-0">
                    <li><a class="dropdown-item" href="#" id="btnExportarExcel"><i class="fas fa-file-excel me-2 text-success"></i>Excel</a></li>
                    <li><a class="dropdown-item" href="#" onclick="window.print()"><i class="fas fa-file-pdf me-2 text-danger"></i>PDF / Imprimir</a></li>
                </ul>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm" style="border-radius: 1rem;">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table id="tabelaAtiv" class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="border-0 px-4 py-3 text-muted fw-bold small">ID</th>
                            <th class="border-0 py-3 text-muted fw-bold small">ATIVIDADE</th>
                            <th class="border-0 py-3 text-muted fw-bold small">DATA</th>
                            <th class="border-0 py-3 text-muted fw-bold small">VOLUNTÁRIOS</th>
                            <th class="border-0 py-3 text-muted fw-bold small">PROJETO / EMPRESA</th>
                            <th class="border-0 py-3 text-muted fw-bold small text-center">AÇÕES</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (locals.listaAtividade && listaAtividade.length > 0) { %>
                            <% listaAtividade.forEach(function(atv) { %>
                                <tr>
                                    <td class="px-4 text-muted small">#<%= atv.atv_id %></td>
                                    <td>
                                        <div class="fw-bold text-dark"><%= atv.atv_nome %></div>
                                        <div class="text-muted small text-truncate" style="max-width: 250px;"><%= atv.atv_desc %></div>
                                    </td>
                                    <td>
                                        <span class="badge rounded-pill bg-purple-soft text-purple px-2 py-1">
                                            <%= new Date(atv.atv_data).toLocaleDateString('pt-BR') %>
                                        </span>
                                    </td>
                                    <td>
                                        <% if (atv.voluntarios && atv.voluntarios.length > 0) { %>
                                            <div class="d-flex flex-wrap gap-1">
                                                <% atv.voluntarios.forEach(v => { %>
                                                    <span class="badge bg-light text-dark border small" style="font-size: 0.65rem;">
                                                        <%= v.pess_nome %>
                                                    </span>
                                                <% }) %>
                                            </div>
                                        <% } else { %>
                                            <span class="text-muted small">Nenhum vinculado</span>
                                        <% } %>
                                    </td>
                                    <td>
                                        <div class="small fw-semibold text-primary"><i class="fas fa-project-diagram me-1"></i>ID Projeto: <%= atv.pro_id %></div>
                                        <% if (atv.emp_id) { %>
                                            <div class="small text-success"><i class="fas fa-building me-1"></i>ID Empresa: <%= atv.emp_id %></div>
                                        <% } %>
                                    </td>
                                    <td class="text-center px-4">
                                        <div class="d-flex justify-content-center gap-2">
                                            <a href="/atividades/alterar/<%= atv.atv_id %>" class="btn btn-sm btn-outline-primary" title="Editar">
                                                <i class="fas fa-pen"></i>
                                            </a>
                                            <button data-codigoexclusao="<%= atv.atv_id %>" class="btn btn-sm btn-outline-danger btnExclusao" title="Excluir">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            <% }); %>
                        <% } else { %>
                            <tr>
                                <td colspan="6" class="text-center py-5 text-muted">
                                    <i class="fas fa-tasks fa-3x mb-3 opacity-25 d-block"></i>
                                    Nenhuma atividade registrada no momento.
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    .bg-purple-soft { background-color: rgba(124, 58, 237, 0.1); }
    .text-purple { color: #7c3aed; }
    .btn-purple { background-color: #7c3aed; color: white; border: none; }
    .btn-purple:hover { background-color: #6d28d9; color: white; }
</style>
