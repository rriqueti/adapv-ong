<%
    // Solução definitiva para evitar ReferenceError no EJS
    const searchNome = (locals.filtros && locals.filtros.nome) ? locals.filtros.nome : '';
    const searchFaixa = (locals.filtros && locals.filtros.faixaEtaria) ? locals.filtros.faixaEtaria : '';
%>
<div class="page-header mb-4">
    <div>
        <h1 class="page-title fw-bold" style="font-size: 2.25rem; font-weight: 800;">Voluntários do SOS Caramelo</h1>
        <p class="text-muted mt-2 mb-0" style="font-size: 1.1rem;">Gerencie a equipe que dedica seu tempo e carinho aos resgatados.</p>
    </div>
    <div class="actions mt-3 mt-md-0 d-flex gap-2">
        <a href="/voluntarios/cadastrar" class="btn btn-purple shadow-sm px-4 py-2" style="border-radius: 0.75rem; background-color: #6100a4; color: white;">
            <i class="fas fa-hand-holding-heart me-2"></i>Novo Voluntário
        </a>
        <button id="btnExportarExcel" class="btn btn-outline-purple px-4 py-2" style="border-radius: 0.75rem; border-color: #6100a4; color: #6100a4;">
            <i class="fas fa-file-excel me-2"></i>Exportar Excel
        </button>
    </div>
</div>

<!-- Filtros de Pesquisa -->
<div class="card shadow-sm border-0 mb-4" style="border-radius: 1rem;">
    <div class="card-body p-4">
        <form action="/voluntarios/listar" method="GET" class="row g-3">
            <div class="col-md-5">
                <label for="nome" class="form-label fw-bold">Nome do Voluntário</label>
                <input type="text" name="nome" id="nome" class="form-control" placeholder="Buscar por nome..." value="<%= searchNome %>">
            </div>
            <div class="col-md-4">
                <label for="faixaEtaria" class="form-label fw-bold">Faixa Etária</label>
                <select name="faixaEtaria" id="faixaEtaria" class="form-select">
                    <option value="">Todas as idades</option>
                    <option value="jovem" <%= searchFaixa === 'jovem' ? 'selected' : '' %>>Jovem (18-25 anos)</option>
                    <option value="adulto" <%= searchFaixa === 'adulto' ? 'selected' : '' %>>Adulto (26-50 anos)</option>
                    <option value="senior" <%= searchFaixa === 'senior' ? 'selected' : '' %>>Sênior (+50 anos)</option>
                </select>
            </div>
            <div class="col-md-3 d-flex align-items-end gap-2">
                <button type="submit" class="btn btn-primary w-100 fw-bold">
                    <i class="fas fa-search me-2"></i>Filtrar
                </button>
                <a href="/voluntarios/listar" class="btn btn-outline-secondary w-100 fw-bold">Limpar</a>
            </div>
        </form>
    </div>
</div>

<div class="card shadow-sm border-0" style="border-radius: 1rem;">
    <div class="card-body p-4">
        <div class="table-responsive">
            <table id="tabelaVoluntarios" class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th class="border-0">Identificação</th>
                        <th class="border-0">Área / Disponibilidade</th>
                        <th class="border-0">Data de Registro</th>
                        <th class="border-0 text-center">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (locals.listaVolun && listaVolun.length > 0) { %>
                        <% for (let i = 0; i < listaVolun.length; i++) { %>
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 45px; height: 45px; background-color: rgba(97, 0, 164, 0.1); color: #6100a4;">
                                            <i class="fas fa-user-friends"></i>
                                        </div>
                                        <div>
                                            <div class="fw-bold text-dark"><%= listaVolun[i].pess_nome %></div>
                                            <small class="text-muted">Cód: #<%= listaVolun[i].vol_id %></small>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <div class="text-dark fw-bold"><%= listaVolun[i].vol_area_atuacao || 'Não informada' %></div>
                                    <small class="text-muted"><i class="far fa-clock me-1"></i><%= listaVolun[i].vol_disponibilidade || 'Não informada' %></small>
                                </td>
                                <td>
                                    <div class="text-dark">
                                        <i class="far fa-calendar-alt me-1 opacity-50"></i>
                                        <%= new Date(listaVolun[i].createdAt).toLocaleDateString('pt-BR') %>
                                    </div>
                                    <small class="text-muted">Atualizado em: <%= new Date(listaVolun[i].updatedAt).toLocaleDateString('pt-BR') %></small>
                                </td>
                                <td class="text-center">
                                    <div class="d-flex justify-content-center gap-2">
                                        <a href="/voluntarios/alterar/<%= listaVolun[i].vol_id %>" class="btn btn-sm btn-outline-primary rounded-pill px-3">
                                            <i class="fas fa-edit me-1"></i>Editar
                                        </a>
                                        <button class="btn btn-sm btn-outline-danger rounded-pill px-3 btnExclusao" data-id="<%= listaVolun[i].vol_id %>">
                                            <i class="fas fa-trash-alt me-1"></i>Excluir
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        <% } %>
                    <% } else { %>
                        <tr>
                            <td colspan="4" class="text-center py-5 text-muted">
                                <i class="fas fa-user-slash d-block fs-1 mb-3 opacity-25"></i>
                                Nenhum voluntário registrado no sistema.
                            </td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<script src="https://cdn.sheetjs.com/xlsx-0.20.2/package/dist/xlsx.full.min.js"></script>
<script>
document.addEventListener('DOMContentLoaded', function() {
    // Exportar Excel
    const btnExcel = document.getElementById('btnExportarExcel');
    if (btnExcel) {
        btnExcel.addEventListener('click', function() {
            const table = document.getElementById("tabelaVoluntarios");
            const wb = XLSX.utils.table_to_book(table);
            XLSX.writeFile(wb, "voluntarios-sos-caramelo.xlsx");
        });
    }
});
</script>
