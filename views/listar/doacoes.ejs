<link rel="stylesheet" type="text/css" media="print" href="/css/print.css">
<script src="https://cdn.sheetjs.com/xlsx-0.20.2/package/dist/xlsx.full.min.js"></script>
<script src="/js/listar/doacoes.js"></script>

<div class="container-fluid py-4">
    <div class="d-flex align-items-center justify-content-between mb-4">
        <div>
            <h1 class="h3 mb-0 fw-bold text-gray-800">Agendamentos de Coleta</h1>
            <p class="text-muted small mb-0">Gerencie as doações agendadas e o status de retirada/entrega.</p>
        </div>
        <div class="d-flex gap-2">
            <a href="/doacoes/cadastrar" class="btn btn-purple shadow-sm fw-bold">
                <i class="fas fa-plus me-2"></i>Novo Agendamento
            </a>
            <button id="btnExportarExcel" class="btn btn-outline-secondary fw-bold">
                <i class="fas fa-file-excel me-2 text-success"></i>Excel
            </button>
        </div>
    </div>

    <div class="card border-0 shadow-sm" style="border-radius: 1rem;">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table id="tabelaDoacoes" class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="border-0 px-4 py-3 text-muted fw-bold small">AGENDAMENTO</th>
                            <th class="border-0 py-3 text-muted fw-bold small">DOADOR</th>
                            <th class="border-0 py-3 text-muted fw-bold small">COLETOR</th>
                            <th class="border-0 py-3 text-muted fw-bold small">DATA</th>
                            <th class="border-0 py-3 text-muted fw-bold small">STATUS</th>
                            <th class="border-0 py-3 text-muted fw-bold small text-center">AÇÕES</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (locals.listaDoacoes && listaDoacoes.length > 0) { %>
                            <% for (let i = 0; i < listaDoacoes.length; i++) { 
                                let nomeDoadorRef = '—';
                                let nomeColetorRef = 'Não atribuído';
                                
                                for (let j = 0; j < listaPess.length; j++) { 
                                    if (listaDoacoes[i].pess_id == listaPess[j].pess_id) {
                                        nomeDoadorRef = listaPess[j].pess_nome; 
                                    } 
                                    if (listaDoacoes[i].pess_id_coletor == listaPess[j].pess_id) {
                                        nomeColetorRef = listaPess[j].pess_nome; 
                                    } 
                                } 

                                // Data formatada 
                                let dataFmt = '—'; 
                                if (listaDoacoes[i].doa_data) { 
                                    dataFmt = new Date(listaDoacoes[i].doa_data).toLocaleDateString('pt-BR');
                                } 

                                // Status visual 
                                const st = listaDoacoes[i].doa_status || 'Pendente'; 
                                let stIcon = 'fa-clock', stBg = '#e0f2fe', stColor = '#0284c7', stBorder = '#7dd3fc'; 
                                if (st === 'Retirado') { 
                                    stIcon = 'fa-truck'; 
                                    stBg = '#fef9c3'; 
                                    stColor = '#a16207'; 
                                    stBorder = '#fde047'; 
                                } else if (st === 'Entregue na ONG') { 
                                    stIcon = 'fa-check-circle'; 
                                    stBg = '#dcfce7'; 
                                    stColor = '#15803d'; 
                                    stBorder = '#86efac'; 
                                } 

                                // Tipo badge 
                                const tipoBg = listaDoacoes[i].doa_tipo === 'Dinheiro' ? 'rgba(22,163,74,0.1)' : 'rgba(124,58,237,0.1)'; 
                                const tipoColor = listaDoacoes[i].doa_tipo === 'Dinheiro' ? '#15803d' : '#7c3aed'; 
                                const tipoIcon = listaDoacoes[i].doa_tipo === 'Dinheiro' ? 'fa-dollar-sign' : 'fa-box'; 
                            %>
                                    <tr>
                                        <!-- Agendamento (Tipo + Descrição + Qtd) -->
                                        <td class="px-4">
                                            <div class="d-flex align-items-center">
                                                <div class="rounded-circle d-flex align-items-center justify-content-center me-3"
                                                    style="width:42px;height:42px;background:<%= tipoBg %>;color:<%= tipoColor %>;flex-shrink:0;">
                                                    <i class="fas <%= tipoIcon %>"></i>
                                                </div>
                                                <div>
                                                    <div class="fw-bold text-dark">
                                                        <%= listaDoacoes[i].doa_desc %>
                                                    </div>
                                                    <div class="d-flex align-items-center gap-2 mt-1">
                                                        <span class="badge rounded-pill"
                                                            style="background:#f3f4f6;color:#374151;font-size:0.65rem;font-weight:700;padding:0.2rem 0.6rem;text-transform:uppercase;">
                                                            <%= listaDoacoes[i].doa_tipo %>
                                                        </span>
                                                        <% if (listaDoacoes[i].doa_qnt && listaDoacoes[i].doa_qnt != 0) { %>
                                                            <small class="text-muted fw-semibold">Qtd: <%= listaDoacoes[i].doa_qnt %></small>
                                                        <% } %>
                                                    </div>
                                                </div>
                                            </div>
                                        </td>

                                        <!-- Doador -->
                                        <td>
                                            <div class="d-flex align-items-center">
                                                <div class="rounded-circle d-flex align-items-center justify-content-center me-2"
                                                    style="width:32px;height:32px;background:rgba(124,58,237,0.1);color:var(--btn-primary-bg);font-size:0.75rem;flex-shrink:0;">
                                                    <i class="fas fa-hand-holding-heart"></i>
                                                </div>
                                                <div>
                                                    <div class="fw-semibold text-dark" style="font-size:0.875rem;">
                                                        <%= listaDoacoes[i].doa_doador || nomeDoadorRef || 'Doador Eventual' %>
                                                    </div>
                                                    <% if (nomeDoadorRef && listaDoacoes[i].doa_doador) { %>
                                                        <small class="text-muted">Vinculado: <%= nomeDoadorRef %></small>
                                                    <% } else if (!listaDoacoes[i].doa_doador && !nomeDoadorRef) { %>
                                                        <small class="text-muted">Anônimo</small>
                                                    <% } %>
                                                </div>
                                            </div>
                                        </td>

                                        <!-- Responsável pela coleta -->
                                        <td>
                                            <div class="d-flex align-items-center">
                                                <div class="rounded-circle d-flex align-items-center justify-content-center me-2"
                                                    style="width:32px;height:32px;background:rgba(34,197,94,0.1);color:#16a34a;font-size:0.75rem;flex-shrink:0;">
                                                    <i class="fas fa-user-check"></i>
                                                </div>
                                                <div>
                                                    <div class="fw-semibold text-dark" style="font-size:0.875rem;">
                                                        <%= nomeColetorRef %>
                                                    </div>
                                                    <small class="text-muted">Voluntário</small>
                                                </div>
                                            </div>
                                        </td>

                                        <!-- Data -->
                                        <td>
                                            <div class="text-dark">
                                                <i class="far fa-calendar-alt me-1 opacity-50"></i>
                                                <%= dataFmt %>
                                            </div>
                                            <small class="text-muted">Cód: #<%= listaDoacoes[i].doa_id %></small>
                                        </td>

                                        <!-- Status -->
                                        <td>
                                            <div class="dropdown">
                                                <button
                                                    class="btn btn-sm dropdown-toggle fw-bold d-flex align-items-center gap-1"
                                                    type="button" data-bs-toggle="dropdown" aria-expanded="false"
                                                    style="font-size:0.75rem;border-radius:2rem;padding:0.3rem 0.85rem;background:<%= stBg %>;color:<%= stColor %>;border:1px solid <%= stBorder %>;">
                                                    <i class="fas <%= stIcon %>" style="font-size:0.65rem;"></i>
                                                    <%= st %>
                                                </button>
                                                <ul class="dropdown-menu dropdown-menu-end shadow border-0"
                                                    style="font-size:0.85rem;border-radius:0.75rem;min-width:180px;">
                                                    <li><h6 class="dropdown-header"><i class="fas fa-exchange-alt me-1"></i>Alterar Status</h6></li>
                                                    <li><hr class="dropdown-divider"></li>
                                                    <li>
                                                        <a class="dropdown-item d-flex align-items-center gap-2 btnStatus"
                                                            data-id="<%= listaDoacoes[i].doa_id %>"
                                                            data-status="Pendente" href="#">
                                                            <i class="fas fa-clock" style="color:#0284c7;"></i> Pendente
                                                        </a>
                                                    </li>
                                                    <li>
                                                        <a class="dropdown-item d-flex align-items-center gap-2 btnStatus"
                                                            data-id="<%= listaDoacoes[i].doa_id %>"
                                                            data-status="Retirado" href="#">
                                                            <i class="fas fa-truck" style="color:#a16207;"></i> Retirado
                                                        </a>
                                                    </li>
                                                    <li>
                                                        <a class="dropdown-item d-flex align-items-center gap-2 btnStatus"
                                                            data-id="<%= listaDoacoes[i].doa_id %>"
                                                            data-status="Entregue na ONG" href="#">
                                                            <i class="fas fa-check-circle" style="color:#15803d;"></i> Entregue na ONG
                                                        </a>
                                                    </li>
                                                </ul>
                                            </div>
                                        </td>

                                        <!-- Ações -->
                                        <td class="text-center px-4">
                                            <div class="d-flex justify-content-center gap-2">
                                                <a href="/doacoes/alterar/<%= listaDoacoes[i].doa_id %>"
                                                    class="btn btn-sm btn-outline-primary" title="Editar">
                                                    <i class="fas fa-pen"></i>
                                                </a>
                                                <button data-codigoexclusao="<%= listaDoacoes[i].doa_id %>"
                                                    class="btn btn-sm btn-outline-danger btnExclusao" title="Excluir">
                                                    <i class="fas fa-trash"></i>
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                            <% } %>
                        <% } else { %>
                            <tr>
                                <td colspan="6" class="text-center py-5 text-muted">
                                    <i class="fas fa-calendar-times d-block fs-1 mb-3 opacity-25"></i>
                                    Nenhum agendamento registrado ainda.
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Modal de Confirmação de Status -->
<div class="modal fade" id="modalConfirmarStatus" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content" style="border-radius: 1.25rem; border: none; overflow: hidden; box-shadow: 0 15px 35px rgba(0,0,0,0.2);">
            <div class="modal-header border-0 pb-0" style="background: linear-gradient(135deg, #7c3aed, #a855f7); color: white; padding: 1.5rem;">
                <h5 class="modal-title fw-bold m-0">Alterar Status</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4 text-center">
                <div class="rounded-circle d-flex align-items-center justify-content-center mx-auto mb-3"
                    id="statusIconBg" style="width: 60px; height: 60px; background: #f3f4f6;">
                    <i class="fas fa-exchange-alt fs-3" id="statusIcon"></i>
                </div>
                <p class="text-muted mb-1 small">Confirmar alteração para:</p>
                <div id="statusBadgeModal" class="badge rounded-pill px-3 py-2 fw-bold mb-3" style="font-size: 0.9rem;"></div>
                <input type="hidden" id="statusTargetId">
                <input type="hidden" id="statusTargetValue">
                <p class="text-secondary small mb-0">Esta ação atualizará o estado do agendamento imediatamente.</p>
            </div>
            <div class="modal-footer border-0 p-4 pt-0 gap-2">
                <button type="button" class="btn btn-light flex-grow-1 fw-bold py-2" data-bs-dismiss="modal" style="border-radius: 0.75rem;">Voltar</button>
                <button type="button" id="btnConfirmarStatusChange" class="btn btn-primary flex-grow-1 fw-bold py-2" style="border-radius: 0.75rem; background: #7c3aed; border: none;">Confirmar</button>
            </div>
        </div>
    </div>
</div>
