<link rel="stylesheet" type="text/css" media="print" href="/css/print.css">
<!-- Se esse script ler uma tabela HTML, ele vai quebrar. Você precisará exportar passando os dados JSON puros para o SheetJS -->
<script src="https://cdn.sheetjs.com/xlsx-0.20.2/package/dist/xlsx.full.min.js"></script>
<script src="/js/listar/animais.js"></script>

<div class="page-header">
    <h1 class="page-title">Pets para Adoção</h1>
    <div class="actions">
        <button id="btnExportarExcel" class="btn-action btn-excel">
            <i class="fas fa-file-excel"></i>
            <span>Excel</span>
        </button>
        <button id="btnExportarPdf" onclick="window.print()" class="btn-action btn-pdf">
            <i class="fas fa-file-pdf"></i>
            <span>PDF</span>
        </button>
        <a href="/animais/cadastrar" class="btn-action btn-novo">
            <i class="fas fa-plus" style="stroke-width: 3;"></i>
            <span>Novo Animal</span>
        </a>
    </div>
</div>

<!-- Tabela Oculta para Exportação (Gambiara aceitável temporária, o ideal é o JS gerar via JSON) -->
<table id="tabelaAnimais" class="d-none">
    <thead>
        <tr>
            <!-- <th>Id</th> -->
            <th>Nome</th>
            <th>Data Nasc.</th>
            <th>Raça</th>
            <th>Sexo</th>
            <th>Espécie</th>
            <th>Disponível</th>
        </tr>
    </thead>
    <tbody>
        <% for (let i=0; i < lista.length; i++) { %>
            <tr>
                <% if (lista[i].ani_disponivel==='Sim' ) { %>
                    <td>
                        <%= lista[i].ani_id %>
                    </td>
                    <td>
                        <%= lista[i].ani_nome %>
                    </td>
                    <td>
                        <%= new Date(lista[i].ani_nascimento).toLocaleDateString('pt-BR', { timeZone: 'UTC' }) %>
                    </td>
                    <td>
                        <%= lista[i].ani_raca %>
                    </td>
                    <td>
                        <%= lista[i].ani_sexo %>
                    </td>
                    <td>
                        <%= lista[i].ani_especie %>
                    </td>
                    <td>
                        <%= lista[i].ani_disponivel %>
                    </td>
                    <% } %>
            </tr>
            <% } %>
    </tbody>
</table>

<!-- Grid de Cards -->
    <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 row-cols-xl-4 g-4">
        <% if (lista.length===0) { %>
            <div class="col-12 text-center py-5 text-muted">
                <i class="fas fa-paw fa-3x mb-3"></i>
                <p>Nenhum animal cadastrado no momento.</p>
            </div>
        <% } %>
        <% for (let i=0; i < lista.length; i++) { %>
            <div class="col d-flex align-items-stretch">
                <div class="animal-card">
                        <div class="img-container">
                            <% if (lista[i].ani_foto) { %>
                                <img src="<%= lista[i].ani_foto %>" alt="Foto de <%= lista[i].ani_nome %>">
                                <% } else { %>
                                    <svg class="placeholder-icon" fill="currentColor" viewBox="0 0 24 24">
                                        <path
                                            d="M12 8c-1.657 0-3 1.343-3 3s1.343 3 3 3 3-1.343 3-3-1.343-3-3-3zm-5.5 0c-1.381 0-2.5 1.119-2.5 2.5s1.119 2.5 2.5 2.5 2.5-1.119 2.5-2.5-1.119-2.5-2.5-2.5zm11 0c-1.381 0-2.5 1.119-2.5 2.5s1.119 2.5 2.5 2.5 2.5-1.119 2.5-2.5-1.119-2.5-2.5-2.5zM12 16.5c-3.314 0-6 2.686-6 6h12c0-3.314-2.686-6-6-6z" />
                                    </svg>
                                    <% } %>

                                        <% let statusClass=lista[i].ani_disponivel==='Sim' ? 'disponivel' : 'adotado' ;
                                            %>
                                            <% let statusText=lista[i].ani_disponivel==='Sim' ? 'Disponível' : 'Adotado'
                                                ; %>
                                                <span class="status-badge <%= statusClass %>">
                                                    <%= statusText %>
                                                </span>
                        </div>

                        <div class="info-body">
                            <h3 class="animal-name">
                                <%= lista[i].ani_nome %>
                            </h3>
                            <p class="animal-description"
                                style="display: -webkit-box; -webkit-line-clamp: 2; line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                                <%= lista[i].ani_descricao || 'Sem descrição cadastrada.' %>
                            </p>

                            <ul class="info-list">
                                <li>
                                    <span class="label">ID</span>
                                    <span>#<%= lista[i].ani_id %></span>
                                </li>
                                <li>
                                    <span class="label">Raça</span>
                                    <span><%= lista[i].ani_raca %></span>
                                </li>
                                <li>
                                    <span class="label">Sexo</span>
                                    <span class="gender-badge <%= (lista[i].ani_sexo || '').toLowerCase() %>">
                                        <%= (lista[i].ani_sexo || '').toLowerCase() === 'macho' ? '♂' : '♀' %> <%= lista[i].ani_sexo %>
                                    </span>
                                </li>
                                <li>
                                    <span class="label">Espécie</span>
                                    <span><%= lista[i].ani_especie %></span>
                                </li>
                                <li>
                                    <span class="label">Nascimento</span>
                                    <span>
                                        <%= new Date(lista[i].ani_nascimento).toLocaleDateString('pt-BR', { timeZone: 'UTC' }) %>
                                    </span>
                                </li>
                                <li>
                                    <span class="label">Esterilizado</span>
                                    <span><%= lista[i].ani_ester %></span>
                                </li>
                            </ul>
                        </div>

                        <div class="actions-footer">
                            <% if (lista[i].ani_disponivel==='Sim' ) { %>
                                <% if (locals.permissoes && locals.permissoes.includes('adocao.solicitar')) { %>
                                    <button class="btn-status-change btnAdotar" data-bs-toggle="modal"
                                        data-bs-target="#adocaoModal" data-animal-id="<%= lista[i].ani_id %>"
                                        data-animal-nome="<%= lista[i].ani_nome %>">
                                        Solicitar Adoção
                                    </button>
                                <% } %>
                                <% } else { %>
                                    <span>&nbsp;</span>
                                    <% } %>

                                        <div class="icon-actions">
                                            <a href="/animais/alterar/<%= lista[i].ani_id %>" class="btn-icon edit"
                                                title="Editar">
                                                <i class="fas fa-pen icon"></i>
                                            </a>
                                            <% if (locals.permissoes && locals.permissoes.includes('animal.excluir')) { %>
                                                <button data-codigoexclusao="<%= lista[i].ani_id %>"
                                                    class="btn-icon delete btnExclusao" title="Excluir">
                                                    <i class="fas fa-trash icon"></i>
                                                </button>
                                            <% } %>
                                        </div>
                        </div>
                    </div>
                </div>
                <% } %>
</div>

<!-- Modal de Adoção -->
<div class="modal fade" id="adocaoModal" tabindex="-1" aria-labelledby="adocaoModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="adocaoModalLabel">Solicitar Adoção</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="formAdocao">
                <div class="modal-body">
                    <p>Você está solicitando a adoção do animal: <strong id="modalAnimalNome"></strong>.</p>
                    <p>A solicitação será registrada em seu nome. Deseja continuar?</p>
                    <input type="hidden" id="modalAnimalId" name="animal">
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-success">Confirmar Solicitação</button>
                </div>
            </form>
        </div>
    </div>
</div>