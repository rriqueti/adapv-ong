<link rel="stylesheet" type="text/css" media="print" href="/css/print.css">
<!-- Se esse script ler uma tabela HTML, ele vai quebrar. Você precisará exportar passando os dados JSON puros para o SheetJS -->
<script src="https://cdn.sheetjs.com/xlsx-0.20.2/package/dist/xlsx.full.min.js"></script>
<script src="/js/listar/animais.js"></script>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 text-gray-800 m-0">Animais Cadastrados</h1>
    <div>
        <a id="novoReg" class="btn btn-primary shadow-sm" href="/animais/cadastrar">
            <i class="fas fa-plus fa-sm text-white-50 mr-1"></i> Novo Animal
        </a>
        <button id="btnExportarExcel" class="btn btn-outline-success shadow-sm ml-2">
            <i class="fas fa-file-excel mr-1"></i> Excel
        </button>
        <button id="btnExportarPdf" onclick="window.print()" class="btn btn-outline-secondary shadow-sm ml-2">
            <i class="fas fa-file-pdf mr-1"></i> PDF
        </button>
    </div>
</div>

<hr>

<!-- Tabela Oculta para Exportação (Gambiara aceitável temporária, o ideal é o JS gerar via JSON) -->
<table id="tabelaAnimais" class="d-none">
    <thead>
        <tr>
            <th>Id</th><th>Nome</th><th>Data Nasc.</th><th>Raça</th><th>Sexo</th>
            <th>Espécie</th><th>Disponível</th>
        </tr>
    </thead>
    <tbody>
        <% for (let i = 0; i < lista.length; i++) { %>
            <tr>
                <td><%= lista[i].ani_id %></td>
                <td><%= lista[i].ani_nome %></td>
                <td><%= new Date(lista[i].ani_nascimento).toLocaleDateString('pt-BR', { timeZone: 'UTC' }) %></td>
                <td><%= lista[i].ani_raca %></td>
                <td><%= lista[i].ani_sexo %></td>
                <td><%= lista[i].ani_especie %></td>
                <td><%= lista[i].ani_disponivel %></td>
            </tr>
        <% } %>
    </tbody>
</table>

<!-- Grid de Cards -->
<div class="row">
    <% if (lista.length === 0) { %>
        <div class="col-12 text-center py-5 text-muted">
            <i class="fas fa-paw fa-3x mb-3"></i>
            <p>Nenhum animal cadastrado no momento.</p>
        </div>
    <% } %>

    <% for (let i = 0; i < lista.length; i++) { 
        // Lógica de cores para badges
        let badgeColor = lista[i].ani_disponivel === 'Sim' ? 'success' : 'warning';
        let sexoIcon = lista[i].ani_sexo === 'Macho' ? 'mars text-primary' : 'venus text-danger';
    %>
    <div class="col-12 col-md-6 col-lg-4 col-xl-3 mb-4 d-flex align-items-stretch">
        <div class="card shadow-sm w-100 border-0">
            <!-- Imagem do Animal -->
            <!-- Alterado para object-fit: contain com fundo cinza para exibir a foto inteira sem quebrar o layout -->
            <img src="<%= lista[i].ani_foto || '/img/sem-foto.jpg' %>" 
                 class="card-img-top bg-light" 
                 alt="Foto de <%= lista[i].ani_nome %>" 
                 style="height: 220px; width: 100%; object-fit: contain; background-color: #f8f9fa;">
            
            <div class="card-body d-flex flex-column">
                <div class="d-flex justify-content-between align-items-start mb-2">
                    <h5 class="card-title font-weight-bold text-dark m-0">
                        <%= lista[i].ani_nome %>
                    </h5>
                    <span class="badge bg-<%= badgeColor %> text-white"><%= lista[i].ani_disponivel %></span>
                </div>

                <p class="card-text text-muted small flex-grow-1" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                    <%= lista[i].ani_descricao || 'Sem descrição cadastrada.' %>
                </p>

                <!-- Dados Etiquetados -->
                <ul class="list-group list-group-flush small mb-3">
                    <li class="list-group-item px-0 py-1 border-0">
                        <i class="fas fa-hashtag text-secondary w-20px text-center mr-1"></i> <strong>ID:</strong> <%= lista[i].ani_id %>
                    </li>
                    <li class="list-group-item px-0 py-1 border-0">
                        <i class="fas fa-paw text-secondary w-20px text-center mr-1"></i> <strong>Raça/Espécie:</strong> <%= lista[i].ani_raca %> (<%= lista[i].ani_especie %>)
                    </li>
                    <li class="list-group-item px-0 py-1 border-0">
                        <i class="fas fa-<%= sexoIcon %> w-20px text-center mr-1"></i> <strong>Sexo:</strong> <%= lista[i].ani_sexo %>
                    </li>
                    <li class="list-group-item px-0 py-1 border-0">
                        <i class="fas fa-calendar-alt text-secondary w-20px text-center mr-1"></i> <strong>Nascimento:</strong> <%= new Date(lista[i].ani_nascimento).toLocaleDateString('pt-BR', { timeZone: 'UTC' }) %>
                    </li>
                    <li class="list-group-item px-0 py-1 border-0">
                        <i class="fas fa-briefcase-medical text-secondary w-20px text-center mr-1"></i> <strong>Esterilizado:</strong> <%= lista[i].ani_ester %>
                    </li>
                </ul>
            </div>

            <!-- Botões de Ação -->
            <div class="card-footer bg-white border-top-0 pt-0 d-flex justify-content-between">
                <% if (lista[i].ani_disponivel === 'Sim') { %>
                    <button class="btn btn-sm btn-success btnAdotar" 
                            data-bs-toggle="modal" 
                            data-bs-target="#adocaoModal"
                            data-animal-id="<%= lista[i].ani_id %>"
                            data-animal-nome="<%= lista[i].ani_nome %>">
                        <i class="fas fa-heart"></i> Adotar
                    </button>
                <% } %>
                <a id="alterabtn" href="/animais/alterar/<%= lista[i].ani_id %>" class="btn btn-sm btn-outline-primary ml-2" title="Editar">
                    <i class="fas fa-pen"></i>
                </a>
                <button id="delbtn" data-codigoexclusao="<%= lista[i].ani_id %>" class="btn btn-sm btn-outline-danger ml-2 btnExclusao" title="Excluir">
                    <i class="fas fa-trash"></i>
                </button>
            </div>
        </div>
    </div>
    <% } %>
</div>

<!-- Modal de Adoção -->
<div class="modal fade" id="adocaoModal" tabindex="-1" aria-labelledby="adocaoModalLabel" aria-hidden="true">
    <div class="modal-dialog">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title" id="adocaoModalLabel">Registrar Adoção</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <form id="formAdocao">
          <div class="modal-body">
            <p>Você está prestes a registrar a adoção para o animal: <strong id="modalAnimalNome"></strong>.</p>
            <input type="hidden" id="modalAnimalId" name="animal">
            
            <div class="mb-3">
              <label for="adotante" class="form-label">Selecione o Adotante</label>
              <% if (typeof listaPessoas !== 'undefined' && listaPessoas.length > 0) { %>
                <select class="form-select" id="adotante" name="adotante" required>
                    <option value="0" selected disabled>-- Escolha uma pessoa --</option>
                    <% listaPessoas.forEach(pessoa => { %>
                      <option value="<%= pessoa.pes_id %>"><%= pessoa.pes_nome %></option>
                    <% }); %>
                </select>
              <% } else { %>
                <div class="alert alert-warning">
                    Nenhuma pessoa cadastrada para adoção. <a href="/pessoa/cadastrar">Cadastre uma pessoa</a> primeiro.
                </div>
              <% } %>
            </div>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
            <button type="submit" class="btn btn-success" <%= (typeof listaPessoas === 'undefined' || listaPessoas.length === 0) ? 'disabled' : '' %>>Confirmar Adoção</button>
          </div>
        </form>
      </div>
    </div>
</div>