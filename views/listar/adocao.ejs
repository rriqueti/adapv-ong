<link rel="stylesheet" href="/css/listar-cards.css">
<script src="/js/listar/adocao.js" defer></script>

<div class="page-header">
    <h1 class="page-title">Gerenciamento de Adoções</h1>
    <div class="actions">
        <!-- Filtros -->
        <div class="filter-buttons">
            <button type="button" class="btn-filter active" data-filter="todos">Todos</button>
            <button type="button" class="btn-filter" data-filter="pendente">Pendentes</button>
            <button type="button" class="btn-filter" data-filter="aprovada">Aprovadas</button>
            <button type="button" class="btn-filter" data-filter="rejeitada">Rejeitadas</button>
        </div>
    </div>
</div>

<div class="row">
    <% if (listaAdocao.length === 0) { %>
        <div class="col-12 text-center py-5 text-muted">
            <i class="fas fa-file-alt fa-3x mb-3"></i>
            <p>Nenhuma solicitação de adoção encontrada.</p>
        </div>
    <% } %>

    <% listaAdocao.forEach(adocao => { %>
        <% 
            let statusComp = (adocao.status || 'pendente').toLowerCase().trim();
            if (statusComp === 'aprovado') statusComp = 'aprovada';
            if (statusComp === 'rejeitado') statusComp = 'rejeitada';

            let statusClass = '';
            if (statusComp === 'aprovada') statusClass = 'aprovada';
            else if (statusComp === 'rejeitada') statusClass = 'rejeitada';
            else statusClass = 'pendente';
        %>
        <div class="col-12 mb-4 d-flex align-items-stretch adocao-card-wrapper" data-status="<%= statusComp %>">
            <div class="adocao-card">
                <span class="status-badge <%= statusClass %>"><%= adocao.status ? adocao.status.charAt(0).toUpperCase() + adocao.status.slice(1) : 'Pendente' %></span>

                <div class="card-body">
                    <div class="info-item">
                        <i class="fas fa-paw icon"></i>
                        <div>
                            <span class="label">Animal:</span>
                            <span class="value"><span class="animal-nome"><%= adocao.ani_nome %></span> (ID: <%= adocao.ani_id %>)</span>
                        </div>
                    </div>
                    <div class="info-item">
                        <i class="fas fa-user icon"></i>
                        <div>
                            <span class="label">Adotante:</span>
                            <span class="value"><%= adocao.pess_nome %> (ID: <%= adocao.pess_id %>)</span>
                        </div>
                    </div>
                    <div class="info-item">
                        <i class="fas fa-calendar-alt icon"></i>
                        <div>
                            <span class="label">Data da Solicitação:</span>
                            <span class="value"><%= new Date(adocao.createdAt).toLocaleDateString('pt-BR', { timeZone: 'UTC' }) %></span>
                        </div>
                    </div>
                </div>

                <% if ((adocao.status || '').toLowerCase() === 'pendente' && locals.permissoes && locals.permissoes.includes('adocao.aprovar')) { %>
                    <div class="card-footer">
                        <button class="btn btn-sm btn-success btn-acao-adocao" data-id="<%= adocao.ado_id %>" data-acao="aprovada">
                            <i class="fas fa-check"></i> Aprovar
                        </button>
                        <button class="btn btn-sm btn-danger btn-acao-adocao" data-id="<%= adocao.ado_id %>" data-acao="rejeitada">
                            <i class="fas fa-times"></i> Rejeitar
                        </button>
                    </div>
                <% } %>
            </div>
        </div>
    <% }) %>
</div>