<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>AdminLTE 3 | Dashboard</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://getbootstrap.com/docs/5.3/assets/css/docs.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <!-- Google Font: Source Sans Pro -->
  <link rel="stylesheet"
    href="https://fonts.googleapis.com/css?family=Source+Sans+Pro:300,400,400i,700&display=fallback">
  <!-- Font Awesome -->
  <link rel="stylesheet" href="/css/fontawesome-free/css/all.min.css">
  <!-- Theme style -->
  <link rel="stylesheet" href="/css/adminlte.min.css">

  <!-- Custom fonts for this template-->
  <link href="/vendor/fontawesome-free/css/all.min.css" rel="stylesheet" type="text/css">
  <link
    href="https://fonts.googleapis.com/css?family=Nunito:200,200i,300,300i,400,400i,600,600i,700,700i,800,800i,900,900i"
    rel="stylesheet">

  <!-- Custom styles for this template-->
  <link href="/css/sb-admin-2.min.css" rel="stylesheet">

</head>

<body class="hold-transition sidebar-mini layout-fixed">
  <div class="wrapper">

    <!-- Navbar -->
    <nav class="main-header navbar navbar-expand navbar-white navbar-light">
      <!-- Left navbar links -->
      <ul class="navbar-nav">
        <li class="nav-item">
          <a class="nav-link" data-widget="pushmenu" href="#" role="button"><i class="fas fa-bars"></i></a>
        </li>
      </ul>

      <!-- Right navbar links -->
    </nav>
    <!-- /.navbar -->

    <style>
      .google-sidebar {
        background-color: #f8f9fa !important;
        font-family: "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
        border-right: 1px solid #e0e0e0;
      }

      .google-sidebar .nav {
        padding-right: 16px;
      }

      .google-nav-item {
        margin-bottom: 2px;
      }

      .google-nav-link {
        color: #3c4043;
        border-radius: 0 50px 50px 0;
        padding: 10px 24px;
        font-weight: 500;
        display: flex;
        align-items: center;
        transition: background-color 0.2s, color 0.2s;
        text-decoration: none;
        cursor: pointer;
      }

      .google-nav-link:hover {
        background-color: #f1f3f4;
        color: #202124;
      }

      .google-nav-link.active {
        background-color: #e8f0fe;
        color: #1a73e8;
      }

      .google-nav-link .nav-icon {
        width: 24px;
        margin-right: 16px;
        font-size: 1.1rem;
        color: #5f6368;
        text-align: center;
      }

      .google-nav-link.active .nav-icon {
        color: #1a73e8;
      }

      .google-nav-link .fa-chevron-down {
        transition: transform 0.2s ease-in-out;
        font-size: 0.8rem;
        margin-left: auto;
        color: #5f6368;
      }

      .google-nav-link[aria-expanded="true"] .fa-chevron-down {
        transform: rotate(180deg);
      }

      .google-submenu {
        padding-left: 56px;
        list-style-type: none;
        margin-bottom: 0;
        padding-top: 4px;
        padding-bottom: 4px;
      }

      .google-submenu-link {
        color: #3c4043;
        padding: 8px 16px;
        display: block;
        border-radius: 0 50px 50px 0;
        text-decoration: none;
        font-size: 0.9rem;
        transition: background-color 0.2s;
      }

      .google-submenu-link:hover {
        background-color: #f1f3f4;
        color: #202124;
      }
    </style>

    <!-- Main Sidebar Container -->
    <aside class="main-sidebar google-sidebar elevation-2">
      
      <!-- Logo da Marca -->
      <a href="/" class="brand-link" style="border-bottom: 1px solid #e0e0e0; color: #3c4043; text-decoration: none;">
        <span class="brand-text font-weight-light" style="padding-left: 1rem; font-weight: 500!important;">Meu Painel</span>
      </a>

      <!-- Sidebar Wrapper -->
      <div class="sidebar">
        <nav class="mt-3">
          <ul class="nav flex-column mb-0">

            <!-- Home (permanece fixo) -->
            <li class="google-nav-item">
              <a href="/" class="google-nav-link active">
                <i class="nav-icon fas fa-home"></i>
                <span>Painel de controle</span>
              </a>
            </li>

            <% 
              // Mapeia categorias para ícones e define a ordem de exibição
              const categoryConfig = {
                'Cadastrar': { icon: 'fas fa-plus-circle', style: 'mt-2' },
                'Listar': { icon: 'fas fa-list', style: '' },
                'Admin': { icon: 'fas fa-shield-alt', style: 'mt-4 pt-2 border-top' }
              };
              const categoryOrder = ['Cadastrar', 'Listar', 'Admin'];
            %>

            <%# Itera sobre as categorias na ordem definida %>
            <% categoryOrder.forEach(categoryName => { %>
              <%# Verifica se existem itens para esta categoria %>
              <% if (locals.menuCategorias && menuCategorias[categoryName]) { %>
                <% const items = menuCategorias[categoryName]; %>
                <% const config = categoryConfig[categoryName]; %>

                <li class="google-nav-item <%= config.style %>">
                  <a class="google-nav-link" data-bs-toggle="collapse" href="#collapse<%= categoryName %>" role="button"
                    aria-expanded="false" aria-controls="collapse<%= categoryName %>">
                    <i class="nav-icon <%= config.icon || 'fas fa-folder' %>"></i>
                    <span><%= categoryName %></span>
                    <i class="fas fa-chevron-down"></i>
                  </a>
                  <div class="collapse" id="collapse<%= categoryName %>">
                    <ul class="google-submenu">
                      <%# Itera sobre os itens de menu dentro da categoria %>
                      <% items.forEach(item => { %>
                        <li><a class="google-submenu-link" href="<%= item.menu_url %>"><%= item.menu_nome_tela %></a></li>
                      <% }); %>
                    </ul>
                  </div>
                </li>
              <% } %>
            <% }); %>

          </ul>
        </nav>
      </div>
    </aside>

    <!-- Content Wrapper. Contains page content -->
    <div class="content-wrapper" style="padding: 20px;min-height: 700px;">
        <div class="card shadow" style="padding:20px;">
          <%- body %>
        </div>
      </div>
      <!-- /.content-wrapper -->
      <footer class="main-footer">
        <strong>Copyright &copy; 2014-2021 <a href="https://adminlte.io">AdminLTE.io</a>.</strong>
        All rights reserved.
        <div class="float-right d-none d-sm-inline-block">
          <b>Version</b> 3.2.0
        </div>
      </footer>

      <!-- Control Sidebar -->
      <aside class="control-sidebar control-sidebar-dark">
        <!-- Control sidebar content goes here -->
      </aside>
      <!-- /.control-sidebar -->
  </div>
  <!-- ./wrapper -->

  <!-- jQuery -->
  <script src="/js/jquery.min.js"></script>
  <!-- Bootstrap 4 -->
  <script src="/js/bootstrap.bundle.min.js"></script>
  <!-- AdminLTE App -->
  <script src="/js/adminlte.js"></script>
  <!-- Bootstrap core JavaScript-->
  <script src="/vendor/jquery/jquery.min.js"></script>
  <script src="/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>

  <!-- Core plugin JavaScript-->
  <script src="/vendor/jquery-easing/jquery.easing.min.js"></script>

  <!-- Custom scripts for all pages-->
  <script src="/js/sb-admin-2.min.js"></script>

  <!-- Page level plugins -->
  <script src="/vendor/chart.js/Chart.min.js"></script>

  <!-- Page level custom scripts -->
  <script src="/js/demo/chart-area-demo.js"></script>
  <script src="/js/demo/chart-pie-demo.js"></script>

  <script src="/js/demo/chart-bars-demo.js"></script>

  <!-- SweetAlert2 for nice popups -->
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</body>

</html>