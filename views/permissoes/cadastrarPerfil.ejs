<div class="container-fluid">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <h1 class="h3 mb-4 text-gray-800 fw-bold">Criar Novo Perfil de Acesso</h1>

            <div class="card shadow-sm border-0" style="border-radius: 1rem;">
                <div class="card-body p-4 p-md-5">
                    <form id="formPerfil">
                        <div class="mb-4">
                            <label for="nome" class="form-label">Nome do Perfil<span class="text-danger">*</span></label>
                            <input type="text" id="nome" class="form-control" placeholder="Ex: Moderador, Assistente Social..." required>
                            <div class="form-text mt-2">Use nomes claros que identifiquem a função no sistema.</div>
                        </div>

                        <div class="mb-4">
                            <label for="descricao" class="form-label">Descrição</label>
                            <textarea id="descricao" class="form-control" rows="3" placeholder="Descreva as responsabilidades deste perfil..."></textarea>
                        </div>

                        <div class="mt-5 d-flex gap-2">
                            <button type="submit" class="btn btn-success px-5 py-2 fw-bold">Criar Perfil</button>
                            <a href="/permissoes" class="btn btn-outline-secondary px-5 py-2">Cancelar</a>
                        </div>
                    </form>
                </div>
            </div>

            <div class="alert alert-info mt-4" style="border-radius: 1rem;">
                <i class="fas fa-info-circle me-2"></i>
                Após criar o perfil, você poderá definir quais permissões específicas ele terá na tela de <strong>Gerenciamento de Permissões</strong>.
            </div>
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    document.getElementById('formPerfil').addEventListener('submit', function(e) {
        e.preventDefault();

        const data = {
            nome: document.getElementById('nome').value,
            descricao: document.getElementById('descricao').value
        };

        Swal.fire({
            title: 'Criar Perfil?',
            text: `O perfil "${data.nome}" será adicionado ao sistema.`,
            icon: 'question',
            showCancelButton: true,
            confirmButtonColor: '#10b981',
            confirmButtonText: 'Confirmar',
            cancelButtonText: 'Cancelar'
        }).then((result) => {
            if (result.isConfirmed) {
                fetch('/permissoes/perfil/cadastrar', {
                    method: 'POST',
                    body: JSON.stringify(data),
                    headers: { 'Content-Type': 'application/json' }
                })
                .then(res => res.json())
                .then(res => {
                    if (res.ok) {
                        Swal.fire({
                            icon: 'success',
                            title: 'Sucesso!',
                            text: res.msg,
                            timer: 2000,
                            showConfirmButton: false
                        }).then(() => {
                            window.location.href = '/permissoes';
                        });
                    } else {
                        Swal.fire('Erro!', res.msg, 'error');
                    }
                })
                .catch(err => {
                    console.error(err);
                    Swal.fire('Erro!', 'Falha de comunicação com o servidor.', 'error');
                });
            }
        });
    });
});
</script>
