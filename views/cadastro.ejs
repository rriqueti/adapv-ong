    <main
        class="flex-grow flex items-center justify-center px-4 pt-12 pb-12 bg-gradient-to-br from-background to-surface-container-low">
        <div class="grid lg:grid-cols-2 gap-12 items-center max-w-6xl w-full">
            <!-- Left Side: Editorial Content -->
            <div class="hidden lg:flex flex-col gap-8">
                <div class="relative group">
                    <div
                        class="absolute -inset-4 bg-primary-container/10 rounded-[2rem] blur-2xl group-hover:bg-primary-container/20 transition-all duration-500">
                    </div>
                    <img alt="Cachorro caramelo sorridente"
                        class="relative rounded-[2rem] shadow-2xl object-cover aspect-[4/5] transform -rotate-2 hover:rotate-0 transition-transform duration-500"
                        data-alt="Close de dois cachorros brincando alegremente no campo"
                        src="https://lh3.googleusercontent.com/aida-public/AB6AXuD84-82xer6oxyma5cw1v8Ei6tO398YvadE-WDhkrFxvtEhDHfZ2yUPqcV2ThkTBmziKgxOj_LTucGy2SXefyia7q5vw7zzE7_t_HB3Y74ZfI0rqNhyc8Toj4Wg8GyI5e8AO1H__WmUgIKaDZYoN8hWdI4ZS1MvQOdICCPaIAKqjhkCF98bMxi6K6QxaHWGyECizyiLF0QYcAcoseVLK1dljLoQwsGd4ObabAuKMZF075i6km1Z-qvpB68BzHduGFPR6RqqY0HZ_F8" />
                </div>
                <div class="space-y-4">
                    <h2 class="text-5xl font-extrabold text-primary leading-tight tracking-tighter">Transforme vidas com
                        um clique.</h2>
                    <p class="text-lg text-on-surface-variant max-w-md font-medium">Ao criar sua conta, você se torna
                        parte de uma rede dedicada a dar um lar para quem mais precisa.</p>
                </div>
            </div>
            <!-- Right Side: Sign Up Card -->
            <div class="w-full flex justify-center">
                <div
                    class="w-full max-w-md bg-surface-container-lowest p-8 md:p-10 rounded-[2.5rem] shadow-[0px_12px_32px_rgba(31,26,34,0.06)] border border-outline-variant/10">
                    <div class="mb-8 text-center md:text-left">
                        <h1 class="text-3xl font-bold text-on-surface tracking-tight mb-2">Crie sua conta e salve vidas
                        </h1>
                        <p class="text-on-surface-variant font-medium">Junte-se à nossa comunidade de cuidado animal.
                        </p>
                    </div>
                    <form class="space-y-5" action="/cadastro" method="POST">
                        <div class="space-y-2">
                            <label class="text-sm font-bold text-on-surface-variant ml-1" for="name">Nome
                                Completo</label>
                            <div class="relative">
                                <span
                                    class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-outline">person</span>
                                <input
                                    class="w-full pl-12 pr-4 py-4 bg-surface-container-highest border-none rounded-xl focus:ring-2 focus:ring-primary/20 focus:bg-surface-container-lowest transition-all duration-300 placeholder:text-outline/60 text-on-surface font-medium"
                                    id="name" name="name" placeholder="Como quer ser chamado?" type="text" />
                            </div>
                        </div>
                        <div class="space-y-2">
                            <label class="text-sm font-bold text-on-surface-variant ml-1" for="email">E-mail</label>
                            <div class="relative">
                                <span
                                    class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-outline">mail</span>
                                <input
                                    class="w-full pl-12 pr-4 py-4 bg-surface-container-highest border-none rounded-xl focus:ring-2 focus:ring-primary/20 focus:bg-surface-container-lowest transition-all duration-300 placeholder:text-outline/60 text-on-surface font-medium"
                                    id="email" name="email" placeholder="seu@email.com" type="email" />
                            </div>
                        </div>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            <div class="space-y-2">
                                <label class="text-sm font-bold text-on-surface-variant ml-1" for="telefone">Telefone</label>
                                <div class="relative">
                                    <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-outline">call</span>
                                    <input class="w-full pl-12 pr-4 py-4 bg-surface-container-highest border-none rounded-xl focus:ring-2 focus:ring-primary/20 focus:bg-surface-container-lowest transition-all duration-300 placeholder:text-outline/60 text-on-surface font-medium" id="telefone" name="telefone" placeholder="(00) 00000-0000" type="tel"/>
                                </div>
                            </div>
                            <div class="space-y-2">
                                <label class="text-sm font-bold text-on-surface-variant ml-1" for="nascimento">Data de Nascimento</label>
                                <div class="relative">
                                    <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-outline">calendar_today</span>
                                    <input class="w-full pl-12 pr-4 py-4 bg-surface-container-highest border-none rounded-xl focus:ring-2 focus:ring-primary/20 focus:bg-surface-container-lowest transition-all duration-300 placeholder:text-outline/60 text-on-surface font-medium" id="nascimento" name="nascimento" type="date"/>
                                </div>
                            </div>
                        </div>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            <div class="space-y-2">
                                <label class="text-sm font-bold text-on-surface-variant ml-1"
                                    for="password">Senha</label>
                                <div class="relative">
                                    <span
                                        class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-outline">lock</span>
                                    <input
                                        class="w-full pl-12 pr-4 py-4 bg-surface-container-highest border-none rounded-xl focus:ring-2 focus:ring-primary/20 focus:bg-surface-container-lowest transition-all duration-300 placeholder:text-outline/60 text-on-surface font-medium"
                                        id="password" name="password" placeholder="••••••••" type="password" />
                                </div>
                            </div>
                            <div class="space-y-2">
                                <label class="text-sm font-bold text-on-surface-variant ml-1"
                                    for="confirm_password">Confirmar</label>
                                <div class="relative">
                                    <span
                                        class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-outline">verified_user</span>
                                    <input
                                        class="w-full pl-12 pr-4 py-4 bg-surface-container-highest border-none rounded-xl focus:ring-2 focus:ring-primary/20 focus:bg-surface-container-lowest transition-all duration-300 placeholder:text-outline/60 text-on-surface font-medium"
                                        id="confirm_password" name="confirm_password" placeholder="••••••••"
                                        type="password" />
                                </div>
                            </div>
                        </div>
                        <button
                            class="w-full bg-primary hover:bg-primary-container text-on-primary font-bold py-4 rounded-xl shadow-lg shadow-primary/20 transition-all duration-300 active:scale-95 text-lg mt-4"
                            type="submit">
                            Cadastrar
                        </button>
                    </form>
                    <div class="my-8 flex items-center gap-4">
                        <div class="flex-grow h-[1px] bg-outline-variant/30"></div>
                        <span class="text-sm font-bold text-outline uppercase tracking-widest">ou use</span>
                        <div class="flex-grow h-[1px] bg-outline-variant/30"></div>
                    </div>
                    <div class="grid grid-cols-2 gap-4">
                        <button
                            class="flex items-center justify-center gap-3 py-3 border border-outline-variant/50 rounded-xl hover:bg-surface-container-low transition-all duration-200 group">
                            <svg class="w-5 h-5" viewbox="0 0 24 24">
                                <path
                                    d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"
                                    fill="#4285F4"></path>
                                <path
                                    d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"
                                    fill="#34A853"></path>
                                <path
                                    d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z"
                                    fill="#FBBC05"></path>
                                <path
                                    d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 12-4.53z"
                                    fill="#EA4335"></path>
                            </svg>
                            <!-- <img alt="Google" class="w-5 h-5" data-alt="Logotipo do Google" src="https://lh3.googleusercontent.com/aida-public/AB6AXuC9G8FkEBuyXJ-9-lR37bKzdJQ0bT6oHATsPKqrW8hoJVpgm0CSMesr8ih5TeLiC5gFLJ0nuxpS76HRVTMyKA9jeFnWm9lGZQ_k-kNh9vhdn-kq3-GEzvbrB1iyPNGAPoQtEgxqGyTj2zvJpVUqsWZq3iiVHARwJPwaAbpmk4AsTnoQjq1T3IFHj02DeV3TR12kxm_62YYm0yo7AduugFiyZhx_Cea3dMDZGCbpovJkfoG1GRe5h7gTXQkG8Qs8qpmjgly-D3ZSlWQ"/> -->
                            <span
                                class="font-bold text-on-surface-variant group-hover:text-primary transition-colors">Google</span>
                        </button>
                        <button
                            class="flex items-center justify-center gap-3 py-3 border border-outline-variant/50 rounded-xl hover:bg-surface-container-low transition-all duration-200 group">
                            <svg class="w-5 h-5" fill="#1877F2" viewbox="0 0 24 24">
                                <path
                                    d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z">
                                </path>
                            </svg>
                            <!-- <img alt="Facebook" class="w-5 h-5" data-alt="Logotipo do Facebook" src="https://lh3.googleusercontent.com/aida-public/AB6AXuB0B_WhFxRoDGl5WlliAMZYdLNYs4tHVt-biRgMjuMe7DeHUeQwRyuYPz9KXUBqW9G21UHp3ajFdDyxYuX9RChjB754q8-mdYrB4mlejWpFdySgdCQABi4C0Ij79l--aC2xM-YDmyAoHcKye2UZGIw3OpPj9H3SVLZtYfwBswncI0kOBW3GrF4NG_cqfvJH1hr0AUuz-N0lMEg5BpzYdVQ_14gjxHLXkB06XlYEnTbuXeUKibjMyx47A-xfHNfWWFEPMDE8jqDxFfo"/> -->
                            <span
                                class="font-bold text-on-surface-variant group-hover:text-primary transition-colors">Facebook</span>
                        </button>
                    </div>
                    <p class="mt-8 text-center text-on-surface-variant font-medium">
                        Já tem uma conta?
                        <a class="text-primary font-bold hover:underline underline-offset-4 ml-1" href="/login">Entre
                            aqui</a>
                    </p>
                </div>
            </div>
        </div>
    </main>
    <!-- Footer -->
    <footer
        class="w-full py-8 px-6 flex flex-col md:flex-row justify-between items-center gap-4 bg-surface-container-low">
        <div class="text-on-surface-variant/70 text-sm font-medium">
            © 2024 S.O.S Caramelo. Todos os direitos reservados.
        </div>
        <div class="flex gap-6">
            <a class="text-[#1f1a22]/60 hover:text-[#6100a4] transition-colors font-medium text-sm"
                href="#">Privacidade</a>
            <a class="text-[#1f1a22]/60 hover:text-[#6100a4] transition-colors font-medium text-sm" href="#">Termos</a>
            <a class="text-[#1f1a22]/60 hover:text-[#6100a4] transition-colors font-medium text-sm" href="#">Contato</a>
        </div>
    </footer>
</body>

