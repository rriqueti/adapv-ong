<div class="container-fluid">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <h1 class="h3 mb-4 text-gray-800 fw-bold">Registrar Novo Voluntário</h1>

            <div class="card shadow-sm border-0" style="border-radius: 1rem;">
                <div class="card-body p-4 p-md-5">
                    <form id="formVoluntario">
                        <% if (typeof msg != "undefined" && msg) { %>
                            <div class="alert alert-info alert-dismissible fade show" role="alert">
                                <%= msg %>
                                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                            </div>
                        <% } %>

                        <!-- Seleção da Pessoa -->
                        <div class="row g-3 mb-4">
                            <h5 class="fw-bold mb-0">Vincular Doador/Pessoa</h5>
                            <div class="col-md-12">
                                <label for="idVolun" class="form-label">Selecione a pessoa que deseja tornar voluntária<span class="text-danger">*</span></label>
                                <select name="idVolun" class="form-select form-select-lg shadow-none" id="idVolun" required>
                                    <option value="" disabled selected>Clique para selecionar...</option>
                                    <% if (locals.listaPessoa) { %>
                                        <% listaPessoa.forEach(function(pessoas) { %>
                                            <option value="<%= pessoas.pess_id %>">
                                                <%= pessoas.pess_nome %> (CPF: <%= pessoas.pess_cpf || 'Não informado' %>)
                                            </option>
                                        <% }); %>
                                    <% } %>
                                </select>
                                <div class="form-text mt-2">
                                    <i class="fas fa-info-circle me-1"></i> Apenas pessoas já cadastradas na base podem ser vinculadas como voluntários.
                                </div>
                            </div>
                        </div>

                        <div class="mt-5 d-flex gap-2">
                            <button type="button" class="btn btn-success px-5 py-2 fw-bold shadow-sm" id="btnCadastrar">
                                <i class="fas fa-save me-2"></i>Confirmar Registro
                            </button>
                            <a href="/voluntarios/listar" class="btn btn-outline-secondary px-5 py-2 rounded-pill" id="cancelar">
                                Cancelar
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="/js/cadastrar/voluntarios.js"></script>